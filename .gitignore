# =========================
# Virtual environments
# =========================
.venv/
venv/
ENV/
env/

# =========================
# Python cache / compiled files
# =========================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# =========================
# IDE / editor / system files
# =========================
.vscode/
.idea/
.DS_Store
Thumbs.db

# =========================
# Logs / temp files
# =========================
logs/
*.log
*.tmp
.cache/
*.cache
.pytest_cache/

# =========================
# Jupyter
# =========================
.ipynb_checkpoints/

# =========================
# Build / packaging
# =========================
build/
dist/
*.egg-info/

# =========================
# YOLO / training outputs
# =========================
runs/
outputs/

# =========================
# Model weights / export artifacts
# =========================
*.pt
*.pth
*.onnx
*.engine
*.torchscript
*.tflite

# =========================
# Large archives
# =========================
*.zip
*.tar
*.gz
*.7z

# =========================
# Videos
# =========================
*.mp4
*.avi
*.mov
*.mkv
*.jpeg

# =========================
# Local datasets
# CVAT export and generated YOLO dataset should stay local
# =========================
data/*

# Keep folder structure
!data/raw/.gitkeep
!data/external/.gitkeep
!data/dataset/images/train/.gitkeep
!data/dataset/images/val/.gitkeep
!data/dataset/labels/train/.gitkeep
!data/dataset/labels/val/.gitkeep
!data/.gitkeep

